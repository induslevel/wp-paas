# ==========================================
# Traefik Configuration Template
# INSTRUCTIONS: Copy this file to .env and update the values below.
# cp .env.example .env
# ==========================================

# Dashboard Domain & Access
DASHBOARD_DOMAIN=traefik-dashboard.yourdomain.com
# Your local network IP to allow bypass access (e.g., your home LAN IP)
ADMIN_IP=192.168.0.50

# Dashboard Basic Auth
# NOTE: You MUST escape the dollar signs with double dollar signs ($$).

# To generate a new password hash and automatically update the line below, copy and run this entire line in your terminal:
# NEW_AUTH=$(htpasswd -nB admin | sed 's/\$/\$\$/g') && sed -i "s|^DASHBOARD_AUTH=.*|DASHBOARD_AUTH=$NEW_AUTH|" .env
DASHBOARD_AUTH=admin:$$apr1$$yourgeneratedhashhere

# Software & Plugin Versions
TRAEFIK_VERSION=v3.6.1
CF_PLUGIN_VERSION=v1.3.0
DOCKER_API_VERSION=1.41

# Traefik Engine Settings
# Set to DEBUG for troubleshooting, INFO for standard access logs, ERROR for silent
TRAEFIK_LOG_LEVEL=INFO

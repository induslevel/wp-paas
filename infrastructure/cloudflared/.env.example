# ==========================================
# Cloudflare Tunnel Configuration
# ==========================================

# Your Secret Tunnel Token (Get this from the Zero Trust Dashboard)
TUNNEL_TOKEN=your_token_here

# Software Version
CLOUDFLARED_VERSION=2026.3.0

# ------------------------------------------
# Advanced Settings (Safe to leave as default)
# ------------------------------------------

# Transport Protocol
# Options: quic (default/faster), http2 (better for strict firewalls)
TUNNEL_PROTOCOL=quic

# Log Level
# Options: debug, info, warn, error
TUNNEL_LOG_LEVEL=info

# Metrics Port
# Port to expose Prometheus health metrics (e.g., 2000)
TUNNEL_METRICS_PORT=2000
